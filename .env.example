# ============================================================
# Weight Tracker — Environment Configuration Template
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.
# ============================================================

# --- PostgreSQL (app database) ---
POSTGRES_USER=weight_user
POSTGRES_PASSWORD=changeme
POSTGRES_DB=weight_tracker
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Assembled from the above — used by SQLAlchemy and Alembic.
# Use "localhost" here for local dev (dev.sh / overmind).
# Docker Compose overrides this with "postgres" via its environment: block.
DATABASE_URL=postgresql+psycopg2://weight_user:changeme@localhost:5432/weight_tracker

# --- Keycloak ---
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=changeme

# Public-facing base URL of Keycloak (must be reachable from the browser)
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=weight-tracker
KEYCLOAK_CLIENT_ID=weight-tracker-frontend

# --- Backend ---
# Comma-separated list of allowed CORS origins
CORS_ORIGINS=http://localhost:5173

# --- Frontend (Vite build-time env vars, must be prefixed VITE_) ---
VITE_KEYCLOAK_URL=http://localhost:8080
VITE_KEYCLOAK_REALM=weight-tracker
VITE_KEYCLOAK_CLIENT_ID=weight-tracker-frontend
